{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "yingmhd-tools",
  "version": "../package.json",
  "identifier": "com.yingmhd.tools",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "YINGMHD Tools",
        "label": "main",
        "width": 600,
        "height": 480,
        "minWidth": 500,
        "minHeight": 300,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "visible": true,
        "closable": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "windowEffects": {
          "effects": ["underWindowBackground", "acrylic"],
          "state": "active",
          "radius": 12
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; worker-src 'self' blob: data:; font-src 'self' data:; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
