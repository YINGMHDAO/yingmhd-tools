{
  "name": "yingmhd-tools",
  "version": "0.1.0",
  "description": "macOS / Windows 通用的开发者工具启动器,类 uTools 的插件化桌面效率工具",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YINGMHDAO/yingmhd-tools.git"
  },
  "homepage": "https://github.com/YINGMHDAO/yingmhd-tools#readme",
  "keywords": [
    "utools",
    "launcher",
    "tauri",
    "devtools",
    "json",
    "port"
  ],
  "type": "module",
  "bin": {
    "yingmhd-tools": "bin/yingmhd-tools.js"
  },
  "files": [
    "bin",
    "binaries"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "npm:prepare": "npm run tauri:build && rm -rf binaries && mkdir -p binaries/macos && cp -R src-tauri/target/release/bundle/macos/*.app binaries/macos/"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-store": "^2.4.3",
    "clsx": "^2.1.1",
    "fuse.js": "^7.4.2",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "oxlint": "^1.69.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
